    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:web": "expo export -p web",
    "test": "tsx --test src/utils/*.test.ts src/services/**/*.test.ts src/models/*.test.ts src/components/**/*.test.ts src/hooks/*.test.ts",
