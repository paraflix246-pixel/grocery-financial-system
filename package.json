    "test:email": "tsx scripts/test-resend-email.mjs",
    "test:emails": "tsx scripts/test-all-emails.mjs",
    "validate:receipt": "tsx scripts/test-deepread-receipt.ts",
    "validate:receipt-paddle": "tsx scripts/diag-receipt-pipeline.ts",
    "build:android:apk": "eas build --platform android --profile preview"
  },
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "rn-mlkit-ocr",
          "react-native-nitro-image"
        ]
      }
    }
