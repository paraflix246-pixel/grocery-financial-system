# Supabase — auth + community price trends
# Project ref example: siypevkmxeivruwnsxai
#
# API keys: Supabase Dashboard → Project Settings → API Keys
#   NEW (recommended): "Publishable and secret API keys" tab
#     sb_publishable_… → EXPO_PUBLIC_SUPABASE_ANON_KEY   (safe in client / Expo bundle)
#     sb_secret_…      → SUPABASE_SERVICE_ROLE_KEY       (Vercel server env ONLY)
#   LEGACY: "Legacy anon, service_role API keys" tab (JWT strings starting with eyJ…)
#     anon         → EXPO_PUBLIC_SUPABASE_ANON_KEY
#     service_role → SUPABASE_SERVICE_ROLE_KEY
#   This app uses createClient(url, key) with no JWT parsing — either format works.
#   Use publishable OR anon for the client key; secret OR service_role for the server key.
#   NEVER put sb_secret_… or service_role in EXPO_PUBLIC_* (it ships in the mobile/web bundle).
#
# Run supabase/migrations/001_price_records.sql and 002_price_records_rls.sql in SQL Editor, then fill in:
EXPO_PUBLIC_SUPABASE_URL=https://siypevkmxeivruwnsxai.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key

# Server-only — set on Vercel (Production + Preview), never EXPO_PUBLIC_:
# SUPABASE_SERVICE_ROLE_KEY=your-secret-or-service_role-key

# Public app URL — used for native OAuth/password-reset redirects (never localhost on device).
# Web uses window.location.origin at runtime; set this on Vercel Production to https://pennypantry.xyz
# (NOT http://localhost:8081 — localhost is ignored in production builds).
# Local web dev uses window.location.origin automatically when Metro is running.
EXPO_PUBLIC_APP_URL=https://pennypantry.xyz

# --- Admin dashboard (/admin) ---
# Comma-separated admin emails promoted on profile sync (requires SUPABASE_SERVICE_ROLE_KEY).
# Run supabase/migrations/007_admin_profiles.sql first.
ADMIN_EMAILS=pennypantry02@gmail.com
# Client-side mirror for routing/paywall bypass before profile sync completes (web + native bundle).
EXPO_PUBLIC_ADMIN_EMAILS=pennypantry02@gmail.com

# --- Google OAuth (Sign in with Google via Supabase) ---
# Credentials live in Supabase Dashboard → Authentication → Providers → Google (not in this file).
# Full DNS + dashboard checklist: DOMAIN_SETUP.md
#
# Supabase Dashboard (Project Settings → General + Authentication → URL Configuration):
#   - Project name: Penny Pantry (shown in Supabase emails; does NOT control Google consent screen)
#   - Site URL: https://pennypantry.xyz (production web origin — apex; www redirects here)
#   - Redirect URLs — add every URL the app may send as redirectTo (wildcards recommended):
#       https://pennypantry.xyz/**
#       https://www.pennypantry.xyz/**
#       http://localhost:8081/**
#       Explicit paths (optional if wildcards are set):
#         http://localhost:8081/onboarding/upgrade
#         http://localhost:8081/onboarding/reset-password
#         http://localhost:8081/reset-password
#         https://pennypantry.xyz/onboarding/upgrade
#         https://pennypantry.xyz/onboarding/reset-password
#         https://pennypantry.xyz/reset-password
#         https://www.pennypantry.xyz/onboarding/upgrade
#         https://www.pennypantry.xyz/onboarding/reset-password
#         https://www.pennypantry.xyz/reset-password
#       Native deep link (when EXPO_PUBLIC_APP_URL is unset — scheme from app.json):
#         groceryfinancialsystem://onboarding/upgrade
#         groceryfinancialsystem://onboarding/reset-password
#         groceryfinancialsystem://reset-password
#     Wildcard optional for Expo dev-client: exp://** (only if testing without EXPO_PUBLIC_APP_URL)
#
# Privacy / Terms (for Google OAuth branding):
#   https://pennypantry.xyz/privacy
#   https://pennypantry.xyz/terms
#
# Google Cloud Console (APIs & Services → Google Auth Platform):
#   - Branding → App name: Penny Pantry (this is what users should see after brand verification)
#   - Branding → App logo: upload your Penny Pantry icon (min 120×120)
#   - Branding → Authorized domains: pennypantry.xyz, www.pennypantry.xyz, your-project.supabase.co
#   - Audience → User type: External; add test users while in Testing
#   - Clients → Web OAuth client:
#       Authorized JavaScript origins: your Site URL origin(s)
#       Authorized redirect URI: copy from Supabase Google provider page
#         (https://<project-ref>.supabase.co/auth/v1/callback)
#   - Data Access → Scopes: openid, userinfo.email, userinfo.profile
#
# If the consent screen shows "undefined" or your *.supabase.co domain instead of Penny Pantry:
#   Google hides unverified app names. Complete Branding → Verify Branding in Google Auth Platform.
#   For production, submit for OAuth app verification. Optionally set a Supabase custom auth domain
#   (e.g. auth.yourdomain.com) so users see your domain instead of *.supabase.co.
#   See https://supabase.com/docs/guides/auth/social-login/auth-google

# Self-hosted PaddleOCR (optional — AI cleanup fallback when DeepRead is primary scan path)
# Local dev: PADDLEOCR_API_URL=http://localhost:8089
# Production: point at a hosted PaddleOCR service (localhost is ignored on Vercel)
PADDLEOCR_API_URL=http://localhost:8089

# DeepRead receipt OCR (primary scan path — required for receipt scanning on web + native)
# Get a key at https://www.deepread.tech/dashboard
# Typical scan: 20–60s (fast pipeline). Long/busy receipts can take up to ~2 minutes.
DEEPREAD_API_KEY=your_deepread_api_key_here
# Native app: proxy route when not using same-origin web server
# EXPO_PUBLIC_RECEIPT_DEEPREAD_API_URL=https://pennypantry.xyz/api/receipt-deepread

# --- Native iOS/Android (Expo managed + dev client, NOT Expo Go) ---
# ML Kit OCR (rn-mlkit-ocr) requires native modules. Use expo-dev-client + prebuild:
#   npx expo prebuild
#   npx expo run:ios    # or: npx expo run:android
# Do not use Expo Go — it cannot load rn-mlkit-ocr.
# Flow: image -> ML Kit OCR -> raw text -> text-only OpenAI -> finalizeReceiptDraft -> validation

# Native app: receipt-parse API for ML Kit + ChatGPT text-only cleanup
# EXPO_PUBLIC_RECEIPT_PARSE_API_URL=https://your-host/api/receipt-parse

# Optional: native app pointing at deployed OCR proxy (legacy Paddle path)
# EXPO_PUBLIC_RECEIPT_OCR_API_URL=https://your-host/api/receipt-ocr
# EXPO_PUBLIC_PADDLEOCR_API_URL=http://localhost:8089

# AI receipt parse (optional ChatGPT/DeepSeek cleanup after DeepRead)
OPENAI_API_KEY=your_openai_api_key_here
# DEEPSEEK_API_KEY=your_deepseek_api_key_here
# OPENAI_RECEIPT_MODEL=gpt-4o-mini
# OCR_SPACE_API_KEY=your_ocr_space_key_here  # fallback when PaddleOCR unavailable

# --- RevenueCat (native Pro billing) ---
# Requires EAS dev client or production build — not Expo Go.
# Dashboard: https://app.revenuecat.com → Project → API keys (public SDK keys below)
# EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=appl_xxxxxxxx
# EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=goog_xxxxxxxx
# Entitlement identifier (must match RevenueCat dashboard):
# EXPO_PUBLIC_REVENUECAT_ENTITLEMENT_PRO=pro
# Offering identifier (default offering in RevenueCat):
# EXPO_PUBLIC_REVENUECAT_OFFERING=default
# Force mock purchases even when RC keys are set (local tier testing):
# EXPO_PUBLIC_REVENUECAT_USE_MOCK=true
#
# Manual setup (App Store Connect + Google Play + RevenueCat):
# 1. Create subscription products: pro_monthly, pro_yearly
# 2. Link products in RevenueCat → Products → Entitlement (pro)
# 3. Add packages to the "default" offering (monthly + annual)
# 4. Add EXPO_PUBLIC_REVENUECAT_* keys to EAS secrets for native builds
# 5. Rebuild: eas build --profile production --platform all

# 5. Rebuild: eas build --profile production --platform all

# --- Welcome email (Resend — server-only on Vercel) ---
# Sends a branded welcome email after email is confirmed (signup link clicked) or on first
# OAuth sign-in (Google/Apple — already confirmed). Requires RESEND_API_KEY +
# SUPABASE_SERVICE_ROLE_KEY on Vercel Production.
#   RESEND_API_KEY=re_…
#   WELCOME_FROM_EMAIL=Penny Pantry <hello@pennypantry.xyz>
#   SUPABASE_SERVICE_ROLE_KEY=sb_secret_… OR legacy service_role JWT
#     (Dashboard → API Keys → Secret key; used for auth.admin.updateUserById after send)
#     Welcome email is blocked if SUPABASE_SERVICE_ROLE_KEY is unset even when Resend is configured.
# Also used by /admin, Stripe webhooks, forgot-password OAuth detection, password-changed
# and email-changed notifications (/api/auth/password-changed-notification,
# /api/auth/email-changed-notification).
# Verify pennypantry.xyz (and hello@pennypantry.xyz) in Resend before sending.
# Re-test after deploy: confirm signup via email link (welcome fires on USER_UPDATED), or sign in
# with Google; reset welcome flags in Supabase Dashboard → Authentication → Users → Raw user meta
# → remove welcome_email_sent / welcome_email_sent_at.
#
# --- Password reset email (Supabase Auth — NOT Resend) ---
# Forgot-password uses Supabase built-in auth emails (resetPasswordForEmail).
# After the user sets a new password on /onboarding/reset-password, Penny Pantry sends a
# separate "password was updated" confirmation via Resend (same RESEND_API_KEY as welcome).
#   Supabase Dashboard → Project Settings → Authentication → SMTP Settings
#   Enable custom SMTP and connect Resend (smtp.resend.com, port 465, API key as password)
#   or another provider. Default Supabase mail is rate-limited and often lands in spam.
# Also verify Site URL + Redirect URLs above include:
#   https://pennypantry.xyz/onboarding/reset-password
# Requires SUPABASE_SERVICE_ROLE_KEY for /api/auth/forgot-password (OAuth-only detection).

# --- Stripe (web Pro billing) ---
# Server-only secrets — add to Vercel Production (and Preview for testing):
# STRIPE_SECRET_KEY=sk_test_… or sk_live_…
# STRIPE_WEBHOOK_SECRET=whsec_…
# STRIPE_PRICE_PRO_MONTHLY=price_…   # $3.99/mo recurring price ID
# STRIPE_PRICE_PRO_YEARLY=price_…    # $39.99/yr recurring price ID
# STRIPE_PRICE_FAMILY_MONTHLY=price_…  # optional separate Family workspace price (falls back to Pro price)
# STRIPE_PRICE_FAMILY_YEARLY=price_…
# EXPO_PUBLIC_WORKSPACE_USE_MOCK=true  # dev mock for workspace Family subscription
# SUPABASE_SERVICE_ROLE_KEY=…        # sb_secret_… or legacy service_role (server only)
#
# Optional local web mock (skips Stripe, uses dev mock tier like RevenueCat mock):
# EXPO_PUBLIC_STRIPE_USE_MOCK=true
#
# Manual setup: see DOMAIN_SETUP.md §7 Stripe — products, webhook URL, Customer Portal, test mode.

# --- Family workspace (Supabase) ---
# Run all migrations in supabase/migrations/ (001–006) in Supabase SQL Editor.
# Enable Realtime: Database → Replication → add shared_lists + workspace_receipts to supabase_realtime.
# Family workspace subscription unlocks multi-user sync (canAccessWorkspaceFeature()).
# Personal Pro does NOT include household sync — Family is a separate workspace plan.

# Kroger product pricing (server-side OAuth — register at https://developer.kroger.com/)
# KROGER_CLIENT_ID=your_kroger_client_id
# KROGER_CLIENT_SECRET=your_kroger_client_secret
# Optional fixed store for pricing (otherwise nearest store to user ZIP is used)
# KROGER_LOCATION_ID=01400432
# KROGER_API_BASE_URL=https://api.kroger.com
# Web/native: proxy route (defaults to same-origin /api/kroger on web)
# EXPO_PUBLIC_KROGER_API_URL=http://localhost:8085/api/kroger

# SerpApi Google Shopping (cross-retailer web prices — https://serpapi.com/)
# SERPAPI_API_KEY=your_serpapi_api_key
