# Cloud OCR (server-side only — never commit real keys)
OCR_SPACE_API_KEY=your_ocr_space_key_here
# GOOGLE_CLOUD_VISION_API_KEY=optional_google_vision_key

# AI receipt scan (recommended: ChatGPT vision)
OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_RECEIPT_MODEL=gpt-4o-mini
# For difficult receipts try: OPENAI_RECEIPT_MODEL=gpt-4o

# Optional fallback text cleanup
# DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Optional: native app pointing at deployed OCR / AI proxies
# EXPO_PUBLIC_OCR_API_URL=https://your-host/api/ocr
# EXPO_PUBLIC_RECEIPT_PARSE_API_URL=https://your-host/api/receipt-parse
