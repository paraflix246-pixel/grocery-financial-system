# Supabase — auth + community price trends
# Project ref example: siypevkmxeivruwnsxai
# Run supabase/migrations/001_price_records.sql and 002_price_records_rls.sql in SQL Editor, then fill in:
EXPO_PUBLIC_SUPABASE_URL=https://siypevkmxeivruwnsxai.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Public app URL — used for native OAuth/password-reset redirects (never localhost on device).
# Web dev uses window.location.origin automatically when Metro is running.
# Set to your Vercel deployment for dev-client builds on physical devices:
EXPO_PUBLIC_APP_URL=https://pennypantry.xyz

# --- Google OAuth (Sign in with Google via Supabase) ---
# Credentials live in Supabase Dashboard → Authentication → Providers → Google (not in this file).
# Full DNS + dashboard checklist: DOMAIN_SETUP.md
#
# Supabase Dashboard (Project Settings → General + Authentication → URL Configuration):
#   - Project name: Penny Pantry (shown in Supabase emails; does NOT control Google consent screen)
#   - Site URL: https://pennypantry.xyz (production web origin — apex; www redirects here)
#   - Redirect URLs — add every URL the app may send as redirectTo (wildcards recommended):
#       https://pennypantry.xyz/**
#       https://www.pennypantry.xyz/**
#       http://localhost:8081/**
#       Explicit paths (optional if wildcards are set):
#         http://localhost:8081/onboarding/upgrade
#         http://localhost:8081/reset-password
#         https://pennypantry.xyz/onboarding/upgrade
#         https://pennypantry.xyz/reset-password
#         https://www.pennypantry.xyz/onboarding/upgrade
#         https://www.pennypantry.xyz/reset-password
#       Native deep link (when EXPO_PUBLIC_APP_URL is unset — scheme from app.json):
#         groceryfinancialsystem://onboarding/upgrade
#         groceryfinancialsystem://reset-password
#     Wildcard optional for Expo dev-client: exp://** (only if testing without EXPO_PUBLIC_APP_URL)
#
# Privacy / Terms (for Google OAuth branding):
#   https://pennypantry.xyz/privacy
#   https://pennypantry.xyz/terms
#
# Google Cloud Console (APIs & Services → Google Auth Platform):
#   - Branding → App name: Penny Pantry (this is what users should see after brand verification)
#   - Branding → App logo: upload your Penny Pantry icon (min 120×120)
#   - Branding → Authorized domains: pennypantry.xyz, www.pennypantry.xyz, your-project.supabase.co
#   - Audience → User type: External; add test users while in Testing
#   - Clients → Web OAuth client:
#       Authorized JavaScript origins: your Site URL origin(s)
#       Authorized redirect URI: copy from Supabase Google provider page
#         (https://<project-ref>.supabase.co/auth/v1/callback)
#   - Data Access → Scopes: openid, userinfo.email, userinfo.profile
#
# If the consent screen shows "undefined" or your *.supabase.co domain instead of Penny Pantry:
#   Google hides unverified app names. Complete Branding → Verify Branding in Google Auth Platform.
#   For production, submit for OAuth app verification. Optionally set a Supabase custom auth domain
#   (e.g. auth.yourdomain.com) so users see your domain instead of *.supabase.co.
#   See https://supabase.com/docs/guides/auth/social-login/auth-google

# Self-hosted PaddleOCR (required for web receipt scanning when DeepRead is not configured)
PADDLEOCR_API_URL=http://localhost:8089

# DeepRead receipt OCR (required for receipt scanning)
# Get a key at https://www.deepread.tech/dashboard
# Typical scan: 20–60s (fast pipeline). Long/busy receipts can take up to ~2 minutes.
DEEPREAD_API_KEY=your_deepread_api_key_here
# Native app: proxy route when not using same-origin web server
# EXPO_PUBLIC_RECEIPT_DEEPREAD_API_URL=https://your-host/api/receipt-deepread

# --- Native iOS/Android (Expo managed + dev client, NOT Expo Go) ---
# ML Kit OCR (rn-mlkit-ocr) requires native modules. Use expo-dev-client + prebuild:
#   npx expo prebuild
#   npx expo run:ios    # or: npx expo run:android
# Do not use Expo Go — it cannot load rn-mlkit-ocr.
# Flow: image -> ML Kit OCR -> raw text -> text-only OpenAI -> finalizeReceiptDraft -> validation

# Native app: receipt-parse API for ML Kit + ChatGPT text-only cleanup
# EXPO_PUBLIC_RECEIPT_PARSE_API_URL=https://your-host/api/receipt-parse

# Optional: native app pointing at deployed OCR proxy (legacy Paddle path)
# EXPO_PUBLIC_RECEIPT_OCR_API_URL=https://your-host/api/receipt-ocr
# EXPO_PUBLIC_PADDLEOCR_API_URL=http://localhost:8089

# AI receipt parse (required for ChatGPT cleanup on web and native)
# OPENAI_API_KEY=your_openai_api_key_here
# DEEPSEEK_API_KEY=your_deepseek_api_key_here
# OPENAI_RECEIPT_MODEL=gpt-4o-mini

# Legacy cloud OCR (not used by default scan flow)
# OCR_SPACE_API_KEY=your_ocr_space_key_here

# Kroger product pricing (server-side OAuth — register at https://developer.kroger.com/)
# KROGER_CLIENT_ID=your_kroger_client_id
# KROGER_CLIENT_SECRET=your_kroger_client_secret
# Optional fixed store for pricing (otherwise nearest store to user ZIP is used)
# KROGER_LOCATION_ID=01400432
# KROGER_API_BASE_URL=https://api.kroger.com
# Web/native: proxy route (defaults to same-origin /api/kroger on web)
# EXPO_PUBLIC_KROGER_API_URL=http://localhost:8085/api/kroger

# SerpApi Google Shopping (cross-retailer web prices — https://serpapi.com/)
# SERPAPI_API_KEY=your_serpapi_api_key
# EXPO_PUBLIC_SERPAPI_API_URL=http://localhost:8085/api/serpapi

# Marketplace deals (Kroger promos + SerpApi + store weekly-ad links)
# EXPO_PUBLIC_MARKETPLACE_API_URL=http://localhost:8085/api/marketplace

# Open Food Facts Open Prices (crowdsourced US prices — https://prices.openfoodfacts.org)
# OPENFOODFACTS_USERNAME=your_openfoodfacts_username
# OPENFOODFACTS_PASSWORD=your_openfoodfacts_password  # quote if value contains #
# OPENFOODFACTS_API_BASE_URL=https://prices.openfoodfacts.org
# Web/native: proxy route (defaults to same-origin /api/openfoodfacts on web)
# EXPO_PUBLIC_OPENFOODFACTS_API_URL=http://localhost:8085/api/openfoodfacts
